# Development image — used by docker-compose for local validation
# No release build: runs mix phx.server directly for faster iteration
FROM elixir:1.18-otp-27

WORKDIR /app

ARG MIX_ENV=dev
ENV MIX_ENV=${MIX_ENV}

RUN apt-get update -q && apt-get install -y --no-install-recommends \
    build-essential git inotify-tools \
    && rm -rf /var/lib/apt/lists/*

RUN mix local.hex --force && mix local.rebar --force

# Install deps first — cached unless mix.exs/mix.lock change
COPY mix.exs mix.lock ./
RUN mix deps.get
RUN mix deps.compile

COPY config config
COPY priv priv
COPY lib lib

RUN mix compile

COPY rel rel

EXPOSE 4000

COPY docker-dev-entrypoint.sh /app/docker-dev-entrypoint.sh
RUN chmod +x /app/docker-dev-entrypoint.sh

ENTRYPOINT ["/app/docker-dev-entrypoint.sh"]
