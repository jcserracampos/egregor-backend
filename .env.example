# Copy to .env and fill in the values
# cp .env.example .env

# Required: OpenRouter API key for all LLM calls
OPENROUTER_API_KEY=sk-or-...

# Required in prod: Phoenix secret key base
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Optional: override individual LLM models
# EMBEDDING_MODEL=openai/text-embedding-3-small
# TAXONOMIST_MODEL=google/gemini-flash-1.5
# ORACLE_MODEL=anthropic/claude-sonnet-4-5
# PHRASE_MODEL=google/gemini-flash-1.5
# CONVERGENT_MODEL=google/gemini-flash-1.5
# NARRATOR_MODEL=anthropic/claude-sonnet-4-5
# SCRIBE_MODEL=openai/whisper-large-v3
